// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model Campaign {
  id                 Int      @id @default(autoincrement())
  shop               String
  productId          String // The Shopify Product GID, e.g., "gid://shopify/Product/12345"
  productTitle       String
  productImage       String? // The '?' makes this optional
  productHandle      String?
  selectedVariantIdsJson String? // Stores a JSON string of variant GIDs
  startDateTime      DateTime
  endDateTime        DateTime
  timezone           String
  tiersJson          String
  leaderDiscount     Int
  leaderMaxQty       Int?     @default(0)
  status             String   @default("DRAFT") // e.g., DRAFT, ACTIVE, EXPIRED
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  scope              String @default("PRODUCT") // "PRODUCT" or "VARIANT"
  countingMethod     String @default("PARTICIPANT") // "PARTICIPANT" or "ITEM_QUANTITY"

// --- NEW FIELDS ---
  startingParticipants Int    @default(0) // For the marketing boost
  sellingPlanId       String?
  sellingPlanGroupId  String?
  
  // ✨ NEW: Memory bank for inventory automation
  originalInventoryState String? @db.Text 

// A Campaign can have many Groups
  groups             Group[]
}

// Represents a single instance of a group buy for a campaign
model Group {
  id           Int      @id @default(autoincrement())
  shareToken   String   @unique @default(cuid()) // A unique, random ID for sharing links
  status       String   @default("OPEN") // Can be OPEN, LOCKED, COMPLETED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  campaignId   Int
  campaign     Campaign @relation(fields: [campaignId], references: [id])
  participants Participant[]
}

model Participant {
  id         Int      @id @default(autoincrement())
  orderId    String // The Shopify order GID (e.g., "gid://shopify/Order/12345")
  customerId String // The Shopify customer GID
  isLeader   Boolean  @default(false)
  createdAt  DateTime @default(now())
  orderCreatedAt   DateTime?
  updatedAt  DateTime @updatedAt
  quantity   Int      @default(1)
  productVariantId String?
  groupId    Int
  group      Group @relation(fields: [groupId], references: [id])
  status     String   @default("ACTIVE")

  @@unique([orderId, productVariantId])
}

model Settings {
  shop                        String   @id
  autoContinueSelling         Boolean  @default(true)
  disableContinueSellingOnEnd Boolean  @default(true)
  
  // ✨ Email Automation Settings
  sendSuccessEmail            Boolean  @default(false)
  sendFailedEmail             Boolean  @default(false)
  successEmailSubject         String?  @default("Great news! Your Group Buy succeeded 🎉")
  successEmailBody            String?  @default("Your group buy reached its goal! Your payment will be captured shortly, and your item is currently being processed for shipping.")
  failedEmailSubject          String?  @default("Update on your Group Buy")
  failedEmailBody             String?  @default("Unfortunately, the group buy did not reach its goal this time. We have canceled your order and voided the payment authorization. No funds were captured.")

  // ✨ Brand & Styling Settings
  emailLogoUrl                String?
  emailStoreAddress           String?
  emailHeaderColor            String?  @default("#000000")

  // ✨ NEW: Enterprise Sync Field
  contactEmail                String?

  // ✨ NEW: Onboarding Gatekeeper
  isOnboarded                 Boolean  @default(false)

  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}