{{ 'progress-bar.css' | asset_url | stylesheet_tag }}

<script type="module" src="{{ 'progress-bar.js' | asset_url }}" defer="defer"></script>

<style>
  /* 🛑 INSTANTLY HIDE SELLING PLANS ON INITIAL PAGE LOAD */
  .shopify-selling-plan-group,
  shopify-payment-terms,
  .product-form__input--selling-plan,
  product-subscriptions {
    display: none !important;
  }
  
  /* Fallback for other custom structures */
  fieldset:has(input[name="selling_plan"]),
  div:has(> input[name="selling_plan"]) {
    display: none !important;
  }

  /* ✨ SMOOTH FADE IN FOR CONTENT */
  @keyframes gb-fade-in-up {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .gb-fade-in-up {
    animation: gb-fade-in-up 0.4s ease-out forwards;
  }
  
  /* ✨ LOADING SPINNER & OVERLAY */
  .gb-loading-overlay {
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    z-index: 10; border-radius: inherit;
    animation: gb-fade-in 0.2s ease-out forwards;
  }
  .gb-spinner {
    width: 28px; height: 28px;
    border: 3px solid var(--gb-progress-bg-color, #e3e3e3);
    border-bottom-color: var(--gb-progress-color, #005bd3);
    border-radius: 50%; display: inline-block;
    animation: gb-rotation 1s linear infinite;
  }
  @keyframes gb-rotation {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  @keyframes gb-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  /* TEST A: Force 100% Width of Parent Container */
  .gb-widget {
    display: block !important; width: 100% !important;
  }
  
  .gb-wrapper {
    width: 100% !important; max-width: 100% !important;
    margin-left: 0 !important; margin-right: 0 !important;
    box-sizing: border-box !important;
  }
</style>

<group-buy-widget class="gb-widget" 
