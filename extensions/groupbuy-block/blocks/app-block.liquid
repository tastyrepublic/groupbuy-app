  data-t-loading="{{ 'general.loading_campaign' | t | escape }}"
  data-t-max="{{ 'general.max' | t | default: 'Max' | escape }}"
  data-t-max-suffix="{{ 'general.max_suffix' | t | default: 'at this price' | escape }}"
  data-badge-format="{{ block.settings.badge_format }}"
  data-progress-format="{{ block.settings.progress_format }}"
  data-clock-layout="{{ block.settings.clock_layout }}"
  data-clock-full-width="{{ block.settings.clock_full_width }}"
  data-currency-symbol="{{ cart.currency.symbol }}"
  data-product-price="{{ product.selected_or_first_available_variant.price | divided_by: 100.0 }}"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
  data-shop="{{ shop.permanent_domain }}"
  data-is-logged-in="{% if customer %}true{% else %}false{% endif %}"
  data-customer-id="{% if customer %}{{ customer.id }}{% endif %}"
  data-login-url="{{ routes.account_login_url }}"
  data-fb-projectid="groupbuy-app-635bf"
  data-scheduled-badges="{% if block.settings.scheduled_show_badges %}true{% else %}false{% endif %}"
  data-editor-preview="{{ block.settings.editor_preview_state }}"
  data-hide-native="{{ block.settings.hide_native_buttons }}"
>
  {%- comment -%} ✨ EMPTY PLACEHOLDER CARD (Holds space so JS can drop the spinner inside) {%- endcomment -%}
  {%- if product.selling_plan_groups.size > 0 -%}
