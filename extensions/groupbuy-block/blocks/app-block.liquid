    --gb-leader-text: {{ block.settings.leader_text_color }};
    --gb-leader-border: {% if block.settings.show_leader_border %}{{ block.settings.leader_border_width }}px solid {{ block.settings.leader_border_color }}{% else %}none{% endif %};
    --gb-leader-radius: {{ block.settings.leader_radius }}px;
