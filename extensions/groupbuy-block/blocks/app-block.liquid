    --gb-qty-height: {{ block.settings.qty_size }}px;
    --gb-btn-bg: {{ block.settings.btn_bg }};
    --gb-btn-text-color: {{ block.settings.btn_text_color }};
    --gb-btn-radius: {{ block.settings.btn_radius }}px;
    --gb-btn-padding: {{ block.settings.btn_size }}px;
