{% comment %}
  Load your CSS file as usual
{% endcomment %}
{{ 'progress-bar.css' | asset_url | stylesheet_tag }}

<script type="module" src="{{ 'progress-bar.js' | asset_url }}" defer="defer"></script>

<style>
  /* 🛑 INSTANTLY HIDE SELLING PLANS ON INITIAL PAGE LOAD */
  .shopify-selling-plan-group,
  shopify-payment-terms,
  .product-form__input--selling-plan,
  product-subscriptions {
    display: none !important;
  }
  
  /* Fallback for other custom structures */
  fieldset:has(input[name="selling_plan"]),
  div:has(> input[name="selling_plan"]) {
    display: none !important;
  }

  /* ✨ SMOOTH FADE IN FOR CONTENT */
  @keyframes gb-fade-in-up {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .gb-fade-in-up {
    animation: gb-fade-in-up 0.4s ease-out forwards;
  }
  
  /* ✨ LOADING SPINNER & OVERLAY */
  .gb-loading-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 10;
    border-radius: inherit;
    animation: gb-fade-in 0.2s ease-out forwards;
  }
  .gb-spinner {
    width: 28px; height: 28px;
    border: 3px solid var(--gb-progress-bg-color, #e3e3e3);
    border-bottom-color: var(--gb-progress-color, #005bd3);
    border-radius: 50%;
    display: inline-block;
    animation: gb-rotation 1s linear infinite;
  }
  @keyframes gb-rotation {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  @keyframes gb-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>

<group-buy-widget class="gb-widget" 
  style="
    --gb-title-display: {% if block.settings.show_title %}block{% else %}none{% endif %};
    --gb-title-size: {{ block.settings.title_size }}px;
    --gb-title-color: {{ block.settings.title_color }};
    --gb-title-align: {{ block.settings.title_align }};
    --gb-title-weight: {{ block.settings.title_weight }};
    --gb-title-style: {{ block.settings.title_style }};
    --gb-desc-display: {% if block.settings.show_desc %}block{% else %}none{% endif %};
    --gb-desc-size: {{ block.settings.desc_size }}px;
    --gb-desc-color: {{ block.settings.desc_color }};
    --gb-desc-weight: {{ block.settings.desc_weight }};
    --gb-desc-style: {{ block.settings.desc_style }};
    --gb-bg-color: {{ block.settings.bg_color }};
    --gb-box-radius: {{ block.settings.box_radius }}px;
    --gb-border: {% if block.settings.show_border %}{{ block.settings.box_border_width }}px solid {{ block.settings.box_border_color | default: '#e3e3e3' }}{% else %}none{% endif %};
    --gb-progress-bg-color: {{ block.settings.progress_bg_color }};
    --gb-progress-color: {{ block.settings.progress_color }};
    --gb-progress-text-color: {{ block.settings.progress_text_color }};
    --gb-progress-height: {{ block.settings.progress_height }}px;
    --gb-progress-radius: {{ block.settings.progress_radius }}px;
    --gb-badge-display: {% if block.settings.show_badges %}flex{% else %}none{% endif %};
    --gb-badge-bg: {{ block.settings.badge_bg }};
    --gb-badge-text: {{ block.settings.badge_text }};
    --gb-badge-border: {% if block.settings.show_badge_border %}{{ block.settings.badge_border_size }}px solid {{ block.settings.badge_border_color }}{% else %}none{% endif %};
    --gb-badge-radius: {{ block.settings.badge_radius }}px;
    --gb-badge-size: {{ block.settings.badge_size }}px;
    --gb-clock-wrapper-bg: {{ block.settings.clock_wrapper_bg }};
    --gb-clock-wrapper-border: {% if block.settings.show_clock_wrapper_border %}{{ block.settings.clock_wrapper_border_width }}px solid {{ block.settings.clock_wrapper_border_color }}{% else %}none{% endif %};
    --gb-clock-wrapper-radius: {{ block.settings.clock_wrapper_radius }}px;
    --gb-clock-bg-color: {{ block.settings.clock_bg_color }};
    --gb-clock-text-color: {{ block.settings.clock_text_color }};
    --gb-clock-radius: {{ block.settings.clock_radius }}px;
    --gb-clock-border: {% if block.settings.show_clock_border %}{{ block.settings.clock_border_width }}px solid {{ block.settings.clock_border_color }}{% else %}none{% endif %};
    --gb-clock-shadow: {% if block.settings.clock_shadow == 0 or block.settings.clock_shadow_opacity == 0 %}none{% else %}0px 4px {{ block.settings.clock_shadow }}px rgba(0,0,0,{{ block.settings.clock_shadow_opacity | divided_by: 100.0 }}){% endif %};
    --gb-clock-size: {{ block.settings.clock_size }}px;
    --gb-qty-height: {{ block.settings.qty_size }}px;
    --gb-btn-bg: {{ block.settings.btn_bg }};
    --gb-btn-text-color: {{ block.settings.btn_text_color }};
    --gb-btn-radius: {{ block.settings.btn_radius }}px;
    --gb-btn-padding: {{ block.settings.btn_size }}px;
    display: block;
  "
  data-title-text="{{ block.settings.title_text | escape }}"
  data-not-included-text="{{ block.settings.not_included_text | escape }}"
  data-badge-format="{{ block.settings.badge_format }}"
  data-progress-format="{{ block.settings.progress_format }}"
  data-clock-layout="{{ block.settings.clock_layout }}"
  data-clock-full-width="{{ block.settings.clock_full_width }}"
  data-currency-symbol="{{ cart.currency.symbol }}"
  data-product-price="{{ product.selected_or_first_available_variant.price | divided_by: 100.0 }}"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
  data-shop="{{ shop.permanent_domain }}"
  data-is-logged-in="{% if customer %}true{% else %}false{% endif %}"
  data-customer-id="{% if customer %}{{ customer.id }}{% endif %}"
  data-login-url="{{ routes.account_login_url }}"
  data-fb-projectid="groupbuy-app-635bf"
>
</group-buy-widget>

